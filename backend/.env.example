# ── T2C Data Ingest backend configuration ───────────────────────────────────────
# Copy to backend/.env and adjust. The same file is consumed by the API and the worker.

ENV=dev

# Same Postgres instance as t2c_data. The ingest product owns the t2c_data_ingest schema
# and only READS users/roles/permissions from the t2c_data schema.
# Host-side (running the app directly): use localhost. In docker-compose the DB host is
# usually host.docker.internal (external DB) or the postgres service name.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/t2c_data

INGEST_DB_SCHEMA=t2c_data_ingest
REFERENCE_DB_SCHEMA=t2c_data

# MUST be identical to the t2c_data backend's JWT_SECRET_KEY so tokens validate here.
JWT_SECRET_KEY=change-me-must-match-t2c-data
JWT_ALGORITHM=HS256

# Login proxy: where to forward credentials to obtain a token (the t2c_data backend).
# The t2c_data /auth/login expects JSON {email, password, mfa_code?}.
#   - Running the API directly on the host:   http://localhost:8000
#   - Running the API in docker-compose:      http://host.docker.internal:8000
#     (inside a container, "localhost" is the container itself, NOT the host.)
# Optional — you can also log in on t2c_data and reuse the token directly.
T2C_DATA_AUTH_BASE_URL=http://localhost:8000

# Spark cluster (local docker by default).
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_JOBS_DIR=/opt/spark/jobs

# CORS for the frontend.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_BASE_URL=http://localhost:5173
