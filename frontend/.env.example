# Frontend configuration (Vite). Copy to frontend/.env.

# Base URL of the ingest API. Leave empty in dev to use the Vite proxy (see vite.config.ts),
# or set to the API origin, e.g. http://localhost:8010
VITE_API_BASE_URL=

# Target the Vite dev proxy forwards /api to (dev only).
VITE_API_TARGET=http://localhost:8010
